---
import type { TocItem } from '../../utils/generateToC';

interface Props {
	toc: TocItem[];
	depth?: number;
	isMobile?: boolean;
	parentLabel?: string;
}

const { toc, isMobile = false, depth = 0, parentLabel } = Astro.props;

const TOC_ICON = {
	Functions:
		'<svg viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M14.7149 7.74818C14.4095 7.57548 14.0359 7.57548 13.7304 7.74818L9.98044 9.86867C9.89177 9.91881 9.81266 9.98134 9.7448 10.0534L14.2228 12.4053L18.7063 10.0596C18.6372 9.98493 18.5561 9.92025 18.4649 9.86867L14.7149 7.74818Z" fill="currentColor"></path><path d="M18.9727 11.0488L14.7222 13.2726V17.9312L18.4649 15.8148C18.7787 15.6374 18.9727 15.3048 18.9727 14.9444V11.0488Z" fill="currentColor"></path><path d="M9.47266 11.04L13.7222 13.2719V17.9307L9.98044 15.8148C9.66666 15.6374 9.47266 15.3048 9.47266 14.9444V11.04Z" fill="currentColor"></path><path d="M8.72266 9.21985C8.85025 9.21985 8.9704 9.25171 9.07559 9.30792C8.6996 9.67497 8.47792 10.1812 8.47275 10.7198H6.22266C5.80844 10.7198 5.47266 10.3841 5.47266 9.96985C5.47266 9.55564 5.80844 9.21985 6.22266 9.21985H8.72266Z" fill="currentColor"></path><path d="M8.22266 11.9796C8.31032 11.9796 8.39446 11.9947 8.47266 12.0223V13.4369C8.39446 13.4646 8.31032 13.4796 8.22266 13.4796H4.72266C4.30844 13.4796 3.97266 13.1438 3.97266 12.7296C3.97266 12.3154 4.30844 11.9796 4.72266 11.9796H8.22266Z" fill="currentColor"></path><path d="M6.22266 14.7296H8.47266V14.9444C8.47266 15.4104 8.63476 15.853 8.91887 16.2037C8.85633 16.2206 8.79055 16.2296 8.72266 16.2296H6.22266C5.80844 16.2296 5.47266 15.8938 5.47266 15.4796C5.47266 15.0654 5.80844 14.7296 6.22266 14.7296Z" fill="currentColor"></path></svg>',
	Properties:
		'<svg viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M4.89453 9.38443V15.4702C4.89453 16.0225 5.34225 16.4702 5.89453 16.4702H11.9803C12.3781 16.4702 12.7597 16.3122 13.041 16.0309L15.4552 13.6167C15.7365 13.3354 15.8945 12.9538 15.8945 12.556V6.97021C15.8945 6.14179 15.223 5.47021 14.3945 5.47021H8.80874C8.41092 5.47021 8.02939 5.62825 7.74808 5.90955L5.33387 8.32377C5.05257 8.60507 4.89453 8.9866 4.89453 9.38443ZM8.80874 6.47021C8.67614 6.47021 8.54896 6.52289 8.45519 6.61666L6.60164 8.47021H11.8945C11.9841 8.47021 12.0709 8.48199 12.1536 8.50409L14.1874 6.47021H8.80874ZM14.8945 7.17732L12.8607 9.21119C12.8828 9.29381 12.8945 9.38064 12.8945 9.47021V14.7631L14.7481 12.9096C14.8419 12.8158 14.8945 12.6886 14.8945 12.556V7.17732Z" fill="currentColor"></path></svg>',
	Events:
		'<svg viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12.788 3.96973H7.81887C7.59378 3.96973 7.39643 4.12014 7.33676 4.33718L5.41219 11.3372C5.32468 11.6555 5.56419 11.9697 5.8943 11.9697H8.32037L7.95957 17.7677C7.94134 18.0607 8.3112 18.2028 8.49384 17.9731L15.0056 9.78085C15.266 9.45322 15.0327 8.96973 14.6142 8.96973H12.108L13.2712 4.5983C13.3556 4.28094 13.1164 3.96973 12.788 3.96973Z" fill="currentColor"></path></svg>',
	Types:
		'<svg viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M7.2 5.7C5.8 5.7 5.1 6.5 5.1 7.9V8.9C5.1 9.7 4.7 10.2 3.9 10.5C4.7 10.8 5.1 11.3 5.1 12.1V13.1C5.1 14.5 5.8 15.3 7.2 15.3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path><path d="M13.8 5.7C15.2 5.7 15.9 6.5 15.9 7.9V8.9C15.9 9.7 16.3 10.2 17.1 10.5C16.3 10.8 15.9 11.3 15.9 12.1V13.1C15.9 14.5 15.2 15.3 13.8 15.3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path><circle cx="8.9" cy="10.5" r="0.85" fill="currentColor"></circle><circle cx="10.5" cy="10.5" r="0.85" fill="currentColor"></circle><circle cx="12.1" cy="10.5" r="0.85" fill="currentColor"></circle></svg>',
} as const;

function getHeadingIcon(depth: number, parent?: string) {
	if (depth !== 1 || !parent) return undefined;
	if (parent in TOC_ICON) return TOC_ICON[parent as keyof typeof TOC_ICON];
	return undefined;
}

function getIconKind(depth: number, parent?: string) {
	if (depth !== 1 || !parent || !(parent in TOC_ICON)) return undefined;
	return parent.toLowerCase();
}
---

<ul class:list={{ isMobile }}>
	{
		toc.map((heading) => (
			<li>
				<a href={'#' + heading.slug}>
					<span>
						{getHeadingIcon(depth, parentLabel) && (
							<span
								class:list={['tocIcon', getIconKind(depth, parentLabel) && `tocIcon-${getIconKind(depth, parentLabel)}`]}
								set:html={getHeadingIcon(depth, parentLabel)}
							/>
						)}
						<span>{heading.text}</span>
					</span>
				</a>
				{heading.children.length > 0 && (
					<Astro.self
						toc={heading.children}
						depth={depth + 1}
						isMobile={isMobile}
						parentLabel={depth === 0 ? heading.text : parentLabel}
					/>
				)}
			</li>
		))
	}
</ul>

<style define:vars={{ depth }}>
	@layer starlight.core {
		ul {
			padding: 0;
			list-style: none;
		}
		a {
			--pad-inline: 0.5rem;
			display: block;
			border-radius: 0.25rem;
			padding-block: 0.25rem;
			padding-inline: calc(1rem * var(--depth) + var(--pad-inline)) var(--pad-inline);
			line-height: 1.25;
		}
		a > span {
			display: inline-flex;
			align-items: center;
			gap: 0.35rem;
		}
		.tocIcon {
			display: inline-flex;
			width: 0.95rem;
			height: 0.95rem;
			flex: 0 0 auto;
			color: var(--sl-color-text);
		}
		/* Color override, to fix text color override*/
		.tocIcon-functions { color: #e26cf4; }
		.tocIcon-properties { color: #1ac8ff; }
		.tocIcon-events { color: #f2ba2a; }
		.tocIcon-types { color: #ffffff; }
		.tocIcon :global(svg) {
			width: 100%;
			height: 100%;
			display: block;
		}
		a[aria-current='true'] {
			color: var(--sl-color-text-accent);
		}
		.isMobile a {
			--pad-inline: 1rem;
			display: flex;
			justify-content: space-between;
			gap: var(--pad-inline);
			border-top: 1px solid var(--sl-color-gray-6);
			border-radius: 0;
			padding-block: 0.5rem;
			color: var(--sl-color-text);
			font-size: var(--sl-text-sm);
			text-decoration: none;
			outline-offset: var(--sl-outline-offset-inside);
		}
		.isMobile:first-child > li:first-child > a {
			border-top: 0;
		}
		.isMobile a[aria-current='true'],
		.isMobile a[aria-current='true']:hover,
		.isMobile a[aria-current='true']:focus {
			color: var(--sl-color-white);
			background-color: unset;
		}
		.isMobile a[aria-current='true']::after {
			content: '';
			width: 1rem;
			background-color: var(--sl-color-text-accent);
			/* Check mark SVG icon */
			-webkit-mask-image: url('data:image/svg+xml;base64,');
			mask-image: url('data:image/svg+xml;base64,');
			-webkit-mask-repeat: no-repeat;
			mask-repeat: no-repeat;
			flex-shrink: 0;
		}
	}
</style>
